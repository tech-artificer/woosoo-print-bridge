<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Trust self-signed certificates for local development server -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">192.168.100.85</domain>
        <trust-anchors>
            <!-- Trust system certificates -->
            <certificates src="system" />
            <!-- Also trust user-installed certificates (self-signed from mkcert) -->
            <certificates src="user" />
        </trust-anchors>
    </domain-config>
    
    <!-- For localhost development (if needed) -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>
</network-security-config>
